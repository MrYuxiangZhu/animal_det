    {
      "name": "Infer | birder fine-grained",
      "type": "python",
      "request": "launch",
      "module": "src.inferencers.birder",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "--config", "configs/default.yaml",
        "--source", "samples/bird.jpg",
        "--output", "outputs/inference/birder_debug.txt"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Debug | Core recognition models",
      "configurations": [
        "Train | openclip",
        "Train | timm"
      ],
      "stopAll": true
    },
    {
      "name": "Debug | Core detection models",
      "configurations": [
        "Train | tiny_detector",
        "Train | grounding_dino"
      ],
      "stopAll": true
    }
  ]
}
